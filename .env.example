APP_NAME=CEMAPROF
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL (production)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=cemaprof
DB_USERNAME=saad
DB_PASSWORD=saad123

# SQLite (development fallback — uncomment to use)
# DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
ADMIN_SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Production security (set when deploying publicly)
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://www.votredomaine.ma
# SESSION_ENCRYPT=true
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=strict

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ── Local : Gmail SMTP (même principe que CV Analyzer) ───────────────────────
# Mot de passe = App Password Google (pas le mot de passe du compte)
# https://myaccount.google.com/apppasswords
MAIL_MAILER=smtp
MAIL_SCHEME=
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=mariosaadsaidi22@gmail.com
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=mariosaadsaidi22@gmail.com
MAIL_FROM_NAME="${APP_NAME}"
MAIL_ADMIN=mariosaadsaidi22@gmail.com

# ── Railway : Resend (remplace Mailtrap — voir docs/EMAILS.md) ───────────────
# MAIL_MAILER=smtp
# MAIL_SCHEME=
# MAIL_HOST=smtp.resend.com
# MAIL_PORT=587
# MAIL_USERNAME=resend
# MAIL_PASSWORD=re_VOTRE_CLE_API
# MAIL_FROM_ADDRESS=onboarding@resend.dev
# MAIL_FROM_NAME="${APP_NAME}"
# MAIL_ADMIN=mariosaadsaidi22@gmail.com

# Notifications email (true/false) — voir docs/EMAILS.md
MAIL_FEATURE_ADMIN_ON_CONTACT=true
MAIL_FEATURE_CLIENT_ACK=true
MAIL_FEATURE_URGENT_QUOTE=true
MAIL_FEATURE_ADMIN_REPLY=true
MAIL_FEATURE_IMPORT_COMPLETED=true
MAIL_FEATURE_WEEKLY_REPORT=true
MAIL_URGENT_QUOTE_MIN_PRODUCTS=2

WHATSAPP_NUMBER=212600000000

VITE_APP_NAME="${APP_NAME}"

# ── Railway / Docker production ─────────────────────────────────────────────
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://votre-app.up.railway.app
# APP_KEY=base64:...   # php artisan key:generate --show
#
# ── Railway PostgreSQL (service Web) ─────────────────────────────────────────
# Keep ONLY these two — remove DB_HOST, DB_PORT, DB_*, DATABASE_PUBLIC_URL:
# DB_CONNECTION=pgsql
# DATABASE_URL=${{Postgres.DATABASE_URL}}   ← use "Add Reference", no quotes
#
# APP_URL=https://votre-app.up.railway.app
# APP_DEBUG=false
# RUN_SEEDER=true   (first deploy only)
#
# SESSION_DRIVER=database
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax
# CACHE_STORE=database
# QUEUE_CONNECTION=sync
# RUN_SEEDER=true          # first deploy only, then set false
# PORT=8080                # injected automatically by Railway
